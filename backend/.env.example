# ============================================================
# CPD Monitor — variáveis de ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA suba o .env para o git
# ============================================================

# Servidor
NODE_ENV=production
PORT=3000

# JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=troque_por_string_aleatoria_longa

# MySQL
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=cpd_user
MYSQL_PASSWORD=senha_segura
MYSQL_DATABASE=cpd_monitor

# InfluxDB
INFLUX_HOST=http://localhost
INFLUX_PORT=8086
INFLUX_DATABASE=cpd_readings
INFLUX_USERNAME=influx_user
INFLUX_PASSWORD=senha_influx

# MQTT Broker (Mosquitto local ou externo)
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
# Porta do servidor MQTT interno (Aedes) — usado se não tiver Mosquitto
AEDES_PORT=1883

# n8n Webhook URL
N8N_WEBHOOK_URL=https://n8n.seudominio.com.br/webhook/cpd-alerts
N8N_WEBHOOK_SECRET=token_secreto_compartilhado_com_n8n

# Heartbeat check: intervalo do cron (padrão: a cada 1 minuto)
HEARTBEAT_CRON=* * * * *
