# ============================================================
# CPD Monitor — variáveis de ambiente
# Copie para .env e preencha com seus valores reais
# NUNCA suba o .env para o git
# ============================================================

# Servidor
NODE_ENV=production
PORT=3001

# JWT (gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
JWT_SECRET=

# MySQL (timezone UTC — não alterar)
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DATABASE=

# InfluxDB 2.x
INFLUX_URL=http://influxdb:8086
INFLUX_TOKEN=
INFLUX_ORG=
INFLUX_BUCKET=

# Mosquitto externo (deixe MQTT_BROKER_HOST vazio para usar Aedes embutido em dev)
MQTT_BROKER_HOST=
MQTT_BROKER_PORT=1883
MQTT_BROKER_USER=cpd-backend
MQTT_BROKER_PASSWORD=
# clientId do backend no broker — use um valor DIFERENTE por ambiente.
# Dev local apontando para o broker de produção NÃO pode usar o mesmo id,
# senão as duas instâncias se derrubam mutuamente (sessão MQTT persistente).
MQTT_BACKEND_CLIENT_ID=cpd-backend

# Porta do servidor MQTT interno (Aedes) — usado se não tiver Mosquitto
AEDES_PORT=1883

# Pipeline de alertas (n8n)
N8N_WEBHOOK_URL=https://n8n.seudominio.com.br/webhook/cpd-alerts
# Mesmo valor configurado como CPD_WEBHOOK_SECRET no ambiente do n8n
N8N_WEBHOOK_SECRET=
# Espaçamento mínimo entre envios de WhatsApp (anti-banimento)
WHATSAPP_SEND_GAP_MS=4000
# Máximo de retentativas de notificação (backoff exponencial: 2^n minutos)
DISPATCH_MAX_RETRIES=5

# Heartbeat check: intervalo do cron (padrão: a cada 1 minuto)
HEARTBEAT_CRON=* * * * *
